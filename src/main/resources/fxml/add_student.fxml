<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #f5f5f5;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AddStudentController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Header -->
    <VBox alignment="CENTER" styleClass="header-box">
        <Label styleClass="header-title" text="➕ Add New Student" />
        <Label styleClass="header-subtitle" text="Register student for 4th Semester" />
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button onAction="#goHome" styleClass="menu-btn" text="← Back to Home" />
    </HBox>

    <VBox alignment="CENTER" maxWidth="500.0" spacing="15.0" styleClass="form-container">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
        </padding>

        <GridPane hgap="15.0" vgap="15.0">
            <Label text="Roll Number:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="rollNoField" promptText="e.g. 21BCE001" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="nameField" promptText="Enter full name" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Email Address:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="emailField" promptText="student@example.com" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label text="Phone Number:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="phoneField" promptText="10-digit number" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        </GridPane>

        <Button maxWidth="Infinity" onAction="#saveStudent" styleClass="action-btn" text="Save Student" />
    </VBox>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #f5f5f5;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.SearchController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Header Area -->
    <VBox alignment="CENTER" styleClass="header-box">
        <Label styleClass="header-title" text="🔍 Search Students" />
    </VBox>
    
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button onAction="#goHome" styleClass="menu-btn" text="← Back to Home" />
    </HBox>

    <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #f8f9fa; -fx-padding: 20; -fx-border-radius: 10; -fx-background-radius: 10;">
        <TextField fx:id="searchField" prefWidth="400.0" promptText="Enter Name or Roll Number..." style="-fx-font-size: 16px; -fx-padding: 10;" />
        <Button onAction="#performSearch" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 10 30; -fx-background-radius: 5;" text="Search" />
    </HBox>

    <TableView fx:id="searchTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idCol" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="rollNoCol" prefWidth="120.0" text="Roll No" />
            <TableColumn fx:id="nameCol" prefWidth="250.0" text="Name" />
            <TableColumn fx:id="semesterCol" prefWidth="100.0" text="Semester" />
            <TableColumn fx:id="actionCol" prefWidth="180.0" text="Actions" />
        </columns>
        <columnResizePolicy>
           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>

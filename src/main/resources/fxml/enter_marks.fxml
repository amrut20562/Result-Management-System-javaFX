<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #f5f5f5;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MarksController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Header Area -->
    <VBox alignment="CENTER" styleClass="header-box">
        <Label styleClass="header-title" text="📝 Enter Marks" />
        <Label styleClass="header-subtitle" text="Input marks for B.E subjects (0-100)" />
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button onAction="#goHome" styleClass="menu-btn" text="← Back to Home" />
    </HBox>

    <VBox alignment="CENTER" maxWidth="500.0" spacing="15.0" styleClass="form-container">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
        </padding>

        <GridPane hgap="15.0" vgap="15.0">
            <Label text="Select Student:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <ComboBox fx:id="studentComboBox" promptText="-- Select Student --" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Select Subject:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <ComboBox fx:id="subjectComboBox" promptText="-- Select Subject --" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Marks Obtained:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="marksField" promptText="e.g. 85" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        </GridPane>

        <Button maxWidth="Infinity" onAction="#saveMarks" styleClass="action-btn" text="Save Marks" />
    </VBox>
    
    <VBox maxWidth="500.0" style="-fx-background-color: #e8f4f8; -fx-padding: 15; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-color: #2196F3; -fx-border-width: 0 0 0 5;">
        <Label style="-fx-font-weight: bold; -fx-text-fill: #333;" text="💡 Tip:" />
        <Label style="-fx-text-fill: #333;" text="If marks already exist for the selected student and subject, they will be updated automatically." wrapText="true" />
    </VBox>
</VBox>

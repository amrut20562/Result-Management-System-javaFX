<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #f5f5f5;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ResultController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Header area -->
    <VBox alignment="CENTER" styleClass="header-box">
        <Label styleClass="header-title" text="🎓 B.E (Artificial Intelligence &amp; Data Science) Result Card" />
        <Label styleClass="header-subtitle" text="Semester 4" />
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button onAction="#goBack" styleClass="menu-btn" text="← Back to Students List" />
        <Button onAction="#downloadPDF" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 10 20; -fx-font-weight: bold; -fx-background-radius: 5;" text="📄 Download PDF" />
    </HBox>

    <!-- Student details -->
    <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;">
        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Student Information" />
        <GridPane hgap="20.0" vgap="10.0">
            <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
            <Label fx:id="studentNameLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
            <Label text="Roll Number:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;" />
            <Label fx:id="rollNoLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <Label text="Semester:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;" />
            <Label fx:id="semesterLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        </GridPane>
    </VBox>

    <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Subject-wise Marks:" />
    
    <TableView fx:id="marksTable" prefHeight="200.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="codeCol" prefWidth="120.0" text="Subject Code" />
            <TableColumn fx:id="nameCol" prefWidth="300.0" text="Subject Name" />
            <TableColumn fx:id="marksCol" prefWidth="150.0" text="Marks Obtained" />
            <TableColumn fx:id="maxMarksCol" prefWidth="120.0" text="Max Marks" />
        </columns>
        <columnResizePolicy>
           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <!-- Result Summary -->
    <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;">
        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Result Summary" />
        <GridPane hgap="40.0" vgap="10.0">
            <Label text="Total Subjects:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Label fx:id="totalSubjectsLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
            <Label text="Total Marks Obtained:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <Label fx:id="totalMarksLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <Label text="Percentage:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <Label fx:id="percentageLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            
            <Label text="Grade:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <Label fx:id="gradeLabel" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            
            <Label text="Status:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <Label fx:id="statusLabel" GridPane.columnIndex="1" GridPane.rowIndex="4" />
        </GridPane>
    </VBox>

</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #f5f5f5;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.StudentController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Header Area -->
    <VBox alignment="CENTER" styleClass="header-box">
        <Label styleClass="header-title" text="👨‍🎓 Students List" />
        <Label styleClass="header-subtitle" text="B.E (Artificial Intelligence &amp; Data Science) 4th Semester" />
    </VBox>
    
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button onAction="#goHome" styleClass="menu-btn" text="← Back to Home" />
    </HBox>

    <TableView fx:id="studentTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idCol" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="rollNoCol" prefWidth="120.0" text="Roll No" />
            <TableColumn fx:id="nameCol" prefWidth="200.0" text="Name" />
            <TableColumn fx:id="semesterCol" prefWidth="80.0" text="Semester" />
            <TableColumn fx:id="actionCol" prefWidth="250.0" text="Actions" />
        </columns>
        <columnResizePolicy>
           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
    
</VBox>
